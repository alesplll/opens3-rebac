GRPC_HOST=0.0.0.0
GRPC_PORT=50052

PG_HOST=postgres-metadata
PG_PORT_INNER=5432
PG_DATABASE_NAME=metadata_db
PG_USER=metadata_user
PG_PASSWORD=metadata_password
PG_SSL_MODE=disable
PG_TIMEOUT=5s
PG_LOGGING=false

KAFKA_BOOTSTRAP=kafka:29092
KAFKA_OBJECT_DELETED_TOPIC=object-deleted
KAFKA_BUCKET_DELETED_TOPIC=bucket-deleted

LOGGER_LEVEL=info
LOGGER_AS_JSON=true
LOGGER_ENABLE_OLTP=true

OTEL_SERVICE_NAME=metadata
OTEL_ENVIRONMENT=development
OTEL_SERVICE_VERSION=0.1.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_METRICS_PUSH_TIMEOUT=10s

RATE_LIMITER_LIMIT=100
RATE_LIMITER_PERIOD=1s
