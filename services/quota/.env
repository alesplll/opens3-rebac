# Quota Service environment variables
# Copy to .env.local for local overrides (gitignored)

# ── gRPC ─────────────────────────────────────────────────────────────────────
GRPC_PORT=50055

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1
# REDIS_PASSWORD=

# Redis flush interval (milliseconds) — how often in-memory state is written to Redis
REDIS_FLUSH_INTERVAL_MS=500

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_GROUP_ID=quota-service
KAFKA_TOPIC_OBJECT_STORED=object-stored
KAFKA_TOPIC_OBJECT_DELETED=object-deleted
KAFKA_TOPIC_BUCKET_DELETED=bucket-deleted
KAFKA_TOPIC_QUOTA_LIMITS_CHANGED=quota-limits-changed
KAFKA_TOPIC_USER_DELETED=user-deleted

# ── Default quotas ────────────────────────────────────────────────────────────
# Applied when no explicit quota is set for a new subject
# -1 = unlimited
DEFAULT_USER_BYTES_LIMIT=10737418240
DEFAULT_USER_OBJECTS_LIMIT=-1
DEFAULT_USER_BUCKETS_LIMIT=100
DEFAULT_BUCKET_BYTES_LIMIT=-1
DEFAULT_BUCKET_OBJECTS_LIMIT=-1

# ── Observability ─────────────────────────────────────────────────────────────
SERVICE_NAME=quota
ENVIRONMENT=development
LOG_LEVEL=info
LOG_JSON=true
OTLP_ENDPOINT=http://localhost:4317
ENABLE_OTLP=false
